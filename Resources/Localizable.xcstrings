            "value": "전체 개방 접근을 활성화하시겠습니까?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vollständigen offenen Zugriff aktivieren?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Activar acceso abierto completo?"
          }
        },
        "fr": {
