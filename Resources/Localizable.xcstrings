    "settings.browser.openTerminalLinks.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When off, links clicked in terminal output open in your default browser."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフの場合、ターミナル出力のリンクはデフォルトブラウザで開きます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
