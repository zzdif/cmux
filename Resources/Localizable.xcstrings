        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La connexion réseau a été perdue lors de la recherche de mises à jour. Réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La connessione di rete è stata persa durante la verifica degli aggiornamenti. Riprova."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Netværksforbindelsen gik tabt under søgning efter opdateringer. Prøv igen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Połączenie sieciowe zostało utracone podczas sprawdzania aktualizacji. Spróbuj ponownie."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
