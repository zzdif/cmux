    "commandPalette.rename.tabConfirmHint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press Enter to apply this tab name, or Escape to cancel."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Enterキーでタブ名を適用、Escapeキーでキャンセルします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按 Enter 应用此标签页名称，或按 Escape 取消。"
