        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque désactivé, les liens cliqués dans la sortie du terminal s'ouvrent dans votre navigateur par défaut."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
